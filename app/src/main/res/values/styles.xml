<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- AI Suggestion Chip Style -->
    <style name="AISuggestionChip" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:background">@drawable/ai_chip_bg</item>
        <item name="android:textColor">#CCCCCC</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>

    <!-- Function Bar Button Style -->
    <style name="FunctionButton">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:background">@drawable/func_btn_bg</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:padding">8dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
    </style>

    <!-- AI Mode Tab Style -->
    <style name="AIModeTab" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:background">@drawable/ai_mode_tab</item>
        <item name="android:textColor">#88FFFFFF</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>
</resources>
