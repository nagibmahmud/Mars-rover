    <!-- Row 2: Bangla consonants (অ ক খ গ ঘ ঙ চ ছ জ ঝ) -->
    <Row>
        <Key android:codes="2474" android:keyLabel="অ" android:keyEdgeFlags="left" android:keyWidth="14.5%p" android:horizontalGap="0.5%p" />
