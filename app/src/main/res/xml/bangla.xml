    <!-- Row 4: AI + EN + Space + ত + Enter -->
    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="-7" android:keyIcon="@drawable/ic_ai" android:keyEdgeFlags="left" android:keyWidth="10%p" android:horizontalGap="0.5%p" />
        <Key android:codes="-6" android:keyLabel="EN" android:keyWidth="10%p" />
        <Key android:codes="2469" android:keyLabel="ত" android:keyWidth="10%p" />
        <Key android:codes="32" android:keyLabel="space" android:keyWidth="46%p" android:isRepeatable="true" />
        <Key android:codes="2470" android:keyLabel="থ" android:keyWidth="10%p" />
