<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="7%p"
    android:horizontalGap="0.5%p"
    android:verticalGap="1%p">

    <!-- Row 1: QWERTYUIOP -->
    <Row>
        <Key android:codes="113" android:keyLabel="Q" android:keyEdgeFlags="left" />
        <Key android:codes="119" android:keyLabel="W" />
        <Key android:codes="101" android:keyLabel="E" />
        <Key android:codes="114" android:keyLabel="R" />
        <Key android:codes="116" android:keyLabel="T" />
        <Key android:codes="121" android:keyLabel="Y" />
        <Key android:codes="117" android:keyLabel="U" />
        <Key android:codes="105" android:keyLabel="I" />
        <Key android:codes="111" android:keyLabel="O" />
        <Key android:codes="112" android:keyLabel="P" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 2: ASDFGHJKL -->
    <Row>
        <Key android:codes="97" android:keyLabel="A" android:keyEdgeFlags="left" android:keyWidth="14.5%p" android:horizontalGap="0.5%p" />
        <Key android:codes="115" android:keyLabel="S" />
        <Key android:codes="100" android:keyLabel="D" />
        <Key android:codes="102" android:keyLabel="F" />
        <Key android:codes="103" android:keyLabel="G" />
        <Key android:codes="104" android:keyLabel="H" />
        <Key android:codes="106" android:keyLabel="J" />
        <Key android:codes="107" android:keyLabel="K" />
        <Key android:codes="108" android:keyLabel="L" android:keyEdgeFlags="right" android:keyWidth="14.5%p" />
    </Row>

    <!-- Row 3: Shift + ZXCVBNM + Backspace -->
    <Row>
        <Key android:codes="-1" android:keyIcon="@drawable/ic_shift" android:keyEdgeFlags="left" android:isModifier="true" android:isSticky="true" android:keyWidth="14.5%p" android:horizontalGap="0.5%p" />
        <Key android:codes="122" android:keyLabel="Z" />
        <Key android:codes="120" android:keyLabel="X" />
        <Key android:codes="99" android:keyLabel="C" />
        <Key android:codes="118" android:keyLabel="V" />
        <Key android:codes="98" android:keyLabel="B" />
        <Key android:codes="110" android:keyLabel="N" />
        <Key android:codes="109" android:keyLabel="M" />
        <Key android:codes="-5" android:keyIcon="@drawable/ic_backspace" android:keyEdgeFlags="right" android:isRepeatable="true" android:keyWidth="14.5%p" />
    </Row>

    <!-- Row 4: AI + 123 + , + Space + . + Enter -->
    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="-7" android:keyIcon="@drawable/ic_ai" android:keyEdgeFlags="left" android:keyWidth="10%p" android:horizontalGap="0.5%p" />
        <Key android:codes="-2" android:keyLabel="123" android:keyWidth="10%p" />
        <Key android:codes="44" android:keyLabel="," android:keyWidth="7%p" />
        <Key android:codes="32" android:keyLabel="space" android:keyWidth="46%p" android:isRepeatable="true" />
        <Key android:codes="46" android:keyLabel="." android:keyWidth="7%p" />
        <Key android:codes="-3" android:keyIcon="@drawable/ic_enter" android:keyEdgeFlags="right" android:keyWidth="12.5%p" />
    </Row>

</Keyboard>
