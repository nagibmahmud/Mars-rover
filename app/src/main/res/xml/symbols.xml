<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="7%p"
    android:horizontalGap="0.5%p"
    android:verticalGap="1%p">

    <!-- Row 1: Numbers 1-0 -->
    <Row>
        <Key android:codes="49" android:keyLabel="1" android:keyEdgeFlags="left" />
        <Key android:codes="50" android:keyLabel="2" />
        <Key android:codes="51" android:keyLabel="3" />
        <Key android:codes="52" android:keyLabel="4" />
        <Key android:codes="53" android:keyLabel="5" />
        <Key android:codes="54" android:keyLabel="6" />
        <Key android:codes="55" android:keyLabel="7" />
        <Key android:codes="56" android:keyLabel="8" />
        <Key android:codes="57" android:keyLabel="9" />
        <Key android:codes="48" android:keyLabel="0" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 2: Symbols -->
    <Row>
        <Key android:codes="64" android:keyLabel="\@" android:keyEdgeFlags="left" />
        <Key android:codes="35" android:keyLabel="\#" />
        <Key android:codes="36" android:keyLabel="$" />
        <Key android:codes="37" android:keyLabel="%" />
        <Key android:codes="38" android:keyLabel="&amp;" />
        <Key android:codes="42" android:keyLabel="*" />
        <Key android:codes="45" android:keyLabel="-" />
        <Key android:codes="61" android:keyLabel="=" />
        <Key android:codes="92" android:keyLabel="\\" />
        <Key android:codes="124" android:keyLabel="|" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 3: More Symbols -->
    <Row>
        <Key android:codes="-2" android:keyLabel="ABC" android:keyEdgeFlags="left" android:keyWidth="14.5%p" android:horizontalGap="0.5%p" />
        <Key android:codes="33" android:keyLabel="!" />
        <Key android:codes="34" android:keyLabel="&quot;" />
        <Key android:codes="39" android:keyLabel="'" />
        <Key android:codes="58" android:keyLabel=":" />
        <Key android:codes="59" android:keyLabel=";" />
        <Key android:codes="47" android:keyLabel="/" />
        <Key android:codes="63" android:keyLabel="\?" />
        <Key android:codes="-5" android:keyIcon="@drawable/ic_backspace" android:keyEdgeFlags="right" android:isRepeatable="true" android:keyWidth="14.5%p" />
    </Row>

    <!-- Row 4: AI + ABC + , + Space + . + Enter -->
    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="-7" android:keyIcon="@drawable/ic_ai" android:keyEdgeFlags="left" android:keyWidth="10%p" android:horizontalGap="0.5%p" />
        <Key android:codes="-2" android:keyLabel="ABC" android:keyWidth="10%p" />
        <Key android:codes="44" android:keyLabel="," android:keyWidth="7%p" />
        <Key android:codes="32" android:keyLabel="space" android:keyWidth="46%p" android:isRepeatable="true" />
        <Key android:codes="46" android:keyLabel="." android:keyWidth="7%p" />
        <Key android:codes="-3" android:keyIcon="@drawable/ic_enter" android:keyEdgeFlags="right" android:keyWidth="12.5%p" />
    </Row>

</Keyboard>
